<Window x:Class="ZZZ_PS_Launcher.CreateProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ZZZ_PS_Launcher"
        mc:Ignorable="d"
        Title="Создание профиля" Height="400" Width="700"
        ResizeMode="CanMinimize"
        Background="LightGray">
    <Grid>
        <Button Content="Сохранить" Click="SaveSettingsButton_Click" Background="WhiteSmoke" Grid.Row="7" VerticalAlignment="Bottom" HorizontalAlignment="Center" Width="100" Height="40" Margin="0,0,0,10"/>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="20"/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition Height="60"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="20*"/>
                <ColumnDefinition Width="11*"/>
            </Grid.ColumnDefinitions>

            <TextBox Name="TextBox_Name" Grid.Row="1" VerticalAlignment="Bottom" Height="23"/>
            <TextBox Name="TextBox_Server" Grid.Row="3" VerticalAlignment="Bottom"  Height="23" />
            <TextBox Name="TextBox_Hoyo" Grid.Row="4" VerticalAlignment="Bottom"  Height="23" />
            <TextBox Name="TextBox_Kcpshim" Grid.Row="5" VerticalAlignment="Bottom"  Height="23" />
            <TextBox Name="TextBox_Client" Grid.Row="6" VerticalAlignment="Bottom"  Height="23" />
            <ComboBox Name="ComboBox_Commit" DisplayMemberPath="Name" SelectedValuePath="Value" Grid.Row="2" VerticalAlignment="Bottom"  Height="23" />
            <Label Grid.Row="1" Content="Имя профиля:" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="16"/>
            <Label Grid.Row="2" Content="Коммит сервера:" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="16"/>
            <Label Grid.Row="3" Content="Путь к папке сервера:" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="16"/>
            <Label Grid.Row="4" Content="Путь к Hoyo-sdk:" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="16"/>
            <Label Grid.Row="5" Content="Путь к Kcpshim:" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="16"/>
            <Label Grid.Row="6" Content="Путь к патчеру клиента (Tentacle или Vortex):" HorizontalAlignment="Left" VerticalAlignment="Top" FontSize="16"/>
            <Button Name="Button_ServerSelect" Content="Указать путь" Click="Select_Click" Background="WhiteSmoke" Grid.Row="3" Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="110" Height="23" Margin="5,0,0,0" />
            <Button Name="Button_HoyoSelect" Content="Указать путь" Click="Select_Click" Background="WhiteSmoke" Grid.Row="4" Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="110" Height="23" Margin="5,0,0,0"/>
            <Button Name="Button_KcpshimSelect" Content="Указать путь" Click="Select_Click" Background="WhiteSmoke" Grid.Row="5" Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="110" Height="23" Margin="5,0,0,0"/>
            <Button Name="Button_ClientSelect" Content="Указать путь" Click="Select_Click" Background="WhiteSmoke" Grid.Row="6" Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Left" Width="110" Height="23" Margin="5,0,0,0"/>
            <Button Name="Button_ServerProfile" Content="Из профиля" Click="FromProfile_Click" Background="WhiteSmoke" Grid.Row="3" Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="110" Height="23" Margin="0,0,5,0" />
            <Button Name="Button_HoyoProfile" Content="Из профиля" Click="FromProfile_Click" Background="WhiteSmoke" Grid.Row="4" Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="110" Height="23" Margin="0,0,5,0"/>
            <Button Name="Button_KcpshimProfile" Content="Из профиля" Click="FromProfile_Click" Background="WhiteSmoke" Grid.Row="5" Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="110" Height="23" Margin="0,0,5,0"/>
            <Button Name="Button_ClientProfile" Content="Из профиля" Click="FromProfile_Click" Background="WhiteSmoke" Grid.Row="6" Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Right" Width="110" Height="23" Margin="0,0,5,0"/>
        </Grid>
    </Grid>
</Window>
