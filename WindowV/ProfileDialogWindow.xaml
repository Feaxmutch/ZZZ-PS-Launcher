<Window x:Class="ZZZ_PS_Launcher.ProfileDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ZZZ_PS_Launcher"
        mc:Ignorable="d"
        Title="выберите профиль" Height="250" Width="300" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ListBox Name="ListBox_Profiles" Grid.Row="0"/>
        <Button Content="OK" Grid.Row="1" Width="80" HorizontalAlignment="Center" Margin="0,10,0,0" Click="ButtonOk_Click"/>
        </Grid>
</Window>
