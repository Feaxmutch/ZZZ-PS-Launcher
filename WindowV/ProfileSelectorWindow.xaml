<Window x:Class="ZZZ_PS_Launcher.WindowV.ProfileSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ZZZ_PS_Launcher.WindowV"
        mc:Ignorable="d"
        Closing="Window_Closing"
        Activated="OnActivated"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        Title="Select Profile" Height="50" Width="200" ResizeMode="NoResize">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>

        <ComboBox Name="ComboBox_Profiles" VerticalAlignment="Top" Height="22" />
        <Button Name="Button_Add" Content="+" Click="OnAddClick" HorizontalAlignment="Left" VerticalAlignment="Top"  Width="29" FontSize="16" Grid.Column="1" Height="22"  />
    </Grid>
</Window>
