<Window x:Class="ZZZ_PS_Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ZZZ_PS_Launcher"
        mc:Ignorable="d"
        Closed="OnClosed"
        WindowStartupLocation="CenterScreen"
        Title="ZZZ-PS-Starter" Height="450" Width="800" ResizeMode="CanMinimize">
    <Grid>
        <Image Source="/content/MainBackground.png" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True"/>
        <Label Name="Label_LaunchProgress" Content="Здесь прогресс запуска" VerticalAlignment="Bottom" HorizontalAlignment="Center" Foreground="White" Background="Black" />
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="305*"/>
                <RowDefinition Height="65"/>
                <RowDefinition Height="65"/>
                <RowDefinition Height="5"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="550*"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="10"/>
            </Grid.ColumnDefinitions>
            <Button BorderThickness="0" Name="Button_Settings" Click="OpenSettings_Click" HorizontalAlignment="Left" VerticalAlignment="Center"  Width="50" Grid.Row="2" Margin="25,0,0,0" Height="50">
                <Button.Background>
                    <ImageBrush ImageSource="/content/settings_button.png"/>
                </Button.Background>
            </Button>
            <Button Name="Button_launch"  Click="Launch_Click" MouseEnter="OnButtonEnter" MouseLeave="OnButtonLeave" Grid.Column="1"   Grid.Row="2" BorderThickness="0" FontWeight="UltraBold" Content="Начать игру" FontSize="18" Padding="30,0,0,0">
                <Button.Background>
                    <ImageBrush ImageSource="/content/PlayButton.png"/>
                </Button.Background>
            </Button>
        </Grid>
    </Grid>
</Window>